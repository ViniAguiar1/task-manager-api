  },
  "components": {
    "schemas": {
      "Project": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "1"
          },
          "title": {
            "type": "string",
            "example": "Design System"
          },
          "type": {
            "type": "string",
            "example": "Front-End"
          },
          "subtype": {
            "type": "string",
            "example": "Development"
          },
          "date": {
            "type": "string",
            "example": "October 20, 2024"
          },
          "color": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "#2C3E3E",
              "#1A2424"
            ]
          },
          "tasksCount": {
            "type": "integer",
            "example": 12
          },
          "completedTasks": {
            "type": "integer",
            "example": 5
          }
        }
      },
      "ProjectInput": {
        "type": "object",
        "required": [
          "title",
          "type",
          "subtype",
          "date",
          "color"
        ],
        "properties": {
          "title": {
            "type": "string",
            "example": "Design System"
          },
          "type": {
            "type": "string",
            "example": "Front-End"
          },
          "subtype": {
            "type": "string",
            "example": "Development"
          },
          "date": {
            "type": "string",
            "example": "October 20, 2024"
          },
          "color": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "#2C3E3E",
              "#1A2424"
            ]
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "1"
          },
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "example": "john.doe@example.com"
          },
          "phone": {
            "type": "string",
            "example": "(99) 99999-9999"
          },
          "cpf": {
            "type": "string",
            "example": "123.456.789-00"
          },
          "photo": {
            "type": "string",
            "example": "https://example.com/photo.jpg"
          }
        }
      },
      "UserInput": {
        "type": "object",
        "required": [
          "name",
          "email",
          "password",
          "phone",
          "cpf",
          "photo"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "example": "john.doe@example.com"
          },
          "password": {
            "type": "string",
            "example": "password123"
          },
          "phone": {
            "type": "string",
            "example": "(99) 99999-9999"
          },
          "cpf": {
            "type": "string",
            "example": "123.456.789-00"
          },
          "photo": {
            "type": "string",
            "example": "https://example.com/photo.jpg"
          }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "1"
          },
          "title": {
            "type": "string",
            "example": "Atualizações no Sistema de Design"
          },
          "deadline": {
            "type": "string",
            "example": "2024-10-24"
          },
          "priority": {
            "type": "string",
            "enum": ["baixa", "media", "alta"],
            "example": "alta"
          },
          "status": {
            "type": "string",
            "enum": ["pendente", "em-progresso", "concluido"],
            "example": "em-progresso"
          },
          "description": {
            "type": "string",
            "example": "Atualizar os componentes do sistema de design."
          },
          "createdAt": {
            "type": "string",
            "example": "2024-10-01"
          },
          "completedAt": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "projectId": {
            "type": "string",
            "example": "1"
          },
          "userId": {
            "type": "string",
            "example": "1"
          },
          "habit": {
            "type": "boolean",
            "example": false
          },
          "priorityColor": {
            "type": "string",
            "example": "#F44336"
          }
        }
      },
      "TaskInput": {
        "type": "object",
        "required": [
          "title",
          "deadline",
          "priority",
          "status",
          "description",
          "projectId"
        ],
        "properties": {
          "title": {
            "type": "string",
            "example": "Atualizações no Sistema de Design"
          },
          "deadline": {
            "type": "string",
            "example": "2024-10-24"
          },
          "priority": {
            "type": "string",
            "enum": ["baixa", "media", "alta"],
            "example": "alta"
          },
          "status": {
            "type": "string",
            "enum": ["pendente", "em-progresso", "concluido"],
            "example": "em-progresso"
          },
          "description": {
            "type": "string",
            "example": "Atualizar os componentes do sistema de design."
          },
          "projectId": {
            "type": "string",
            "example": "1"
          },
          "habit": {
            "type": "boolean",
            "example": false
          }
        }
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}